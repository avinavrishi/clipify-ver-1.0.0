# =============================================================================
# Environment variables – one file for both the FastAPI app and the worker
# =============================================================================
# Copy this to .env in the project root and set values. Do not commit .env.
#
# Where they are used:
#   - App (FastAPI): loaded automatically from .env by app/core/config.py
#   - Worker: loaded from this same .env when you run: python -m worker.main
#             (from the project root)
# =============================================================================

# -----------------------------------------------------------------------------
# App (FastAPI)
# -----------------------------------------------------------------------------
# DATABASE_URL=sqlite:///./brandfluence.db
# SECRET_KEY=your-secret-key-change-in-production
# DEBUG=true
# Admin bootstrap: when both are set, the app creates an admin user on startup if one does not exist
# ADMIN_BOOTSTRAP_EMAIL=admin@gmail.com
# ADMIN_BOOTSTRAP_PASSWORD=Admin@123
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# SOCIAL_VERIFICATION_CODE_PREFIX=BIMS
# SOCIAL_VERIFICATION_CODE_EXPIRE_MINUTES=10

# OTP registration (optional overrides)
# OTP_EXPIRE_MINUTES=10
# REGISTRATION_TOKEN_EXPIRE_MINUTES=15

# Google OAuth – Login with Google
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# OAUTH_FRONTEND_CALLBACK_URL=http://localhost:3000/auth/callback

# Seed data (optional; used by scripts/campaign_seeds.py)
# SEED_BRAND_EMAIL=brand1@gmail.com
# SEED_BRAND_PASSWORD=Brand@123
# SEED_BRAND_COMPANY_NAME=Demo Brand Co
# SEED_BRAND_INDUSTRY=Technology
# SEED_BRAND_WEBSITE=https://demobrand.example.com

# SEED_CREATOR_EMAIL=user1@gmail.com
# SEED_CREATOR_PASSWORD=Creator@123
# SEED_CREATOR_DISPLAY_NAME=Demo Creator

# SMTP (Gmail) – required for OTP emails
# SMTP_USER=yourgmail@gmail.com
# SMTP_APP_PASSWORD=your_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# -----------------------------------------------------------------------------
# RabbitMQ (used by both App and Worker – must match)
# -----------------------------------------------------------------------------
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# INSTAGRAM_VERIFICATION_QUEUE=instagram_verification
# INSTAGRAM_VERIFICATION_ENABLED=true

# -----------------------------------------------------------------------------
# Worker only (Instagram verification)
# -----------------------------------------------------------------------------
# Optional: path to save/load Playwright session (avoids logging in every time)
# INSTAGRAM_SESSION_STATE_PATH=worker/instagram_state.json

# Optional: auto-login when session is missing or expired (e.g. on a server)
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

# Instagram login form XPaths – required for auto-login. Update these if Instagram changes their DOM.
INSTAGRAM_XPATH_USERNAME=//*[@id="_R_32d9lplcldcpbn6b5ipamH1_"]
INSTAGRAM_XPATH_PASSWORD=//*[@id="_R_33d9lplcldcpbn6b5ipamH1_"]
INSTAGRAM_XPATH_LOGIN_BUTTON=//*[@id="login_form"]/div/div[1]/div/div[3]/div/div/div

# -----------------------------------------------------------------------------
# Database (Worker uses this to update verification status)
# -----------------------------------------------------------------------------
# DATABASE_URL=sqlite:///./brandfluence.db
